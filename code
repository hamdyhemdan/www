<html>
<body>
    <h1>الرابط الحالي:</h1>
    <a id="link" href="#">جاري التحميل...</a>
    <script>
        fetch('link.txt').then(r => r.text()).then(t => {
            document.getElementById('link').href = t;
            document.getElementById('link').innerText = t;
        });
    </script>
</body>
</html>
